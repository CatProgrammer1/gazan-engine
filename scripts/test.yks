import "gl"
import "gl_input"

yar maxShadowResolution i32 = (1024 * 6)?i32

yar vertexShader Shader = LoadShader("shaders/main.vs", GL_VERTEX_SHADER)
yar fragShader Shader = LoadShader("shaders/main.fs", GL_FRAGMENT_SHADER)

yar shaderProgram ShaderProgram = MakeShaderProgram([vertexShader, fragShader,] <- Shader)

yar vertexShaderDepth Shader = LoadShader("shaders/depth.vs", GL_VERTEX_SHADER)
yar fragShaderDepth Shader = LoadShader("shaders/depth.fs", GL_FRAGMENT_SHADER)

yar depthProgram ShaderProgram = MakeShaderProgram([vertexShaderDepth, fragShaderDepth,] <- Shader)

yar vertexShaderDepthP Shader = LoadShader("shaders/depth_p.vs", GL_VERTEX_SHADER)
yar geomShaderDepthP Shader = LoadShader("shaders/depth_p.gs", GL_GEOMETRY_SHADER)
yar fragShaderDepthP Shader = LoadShader("shaders/depth_p.fs", GL_FRAGMENT_SHADER)

yar depthProgramPoint ShaderProgram = MakeShaderProgram([vertexShaderDepthP, geomShaderDepthP, fragShaderDepthP,] <- Shader)

yar shadowMapDir ShadowMap = NewShadowMap(depthProgram, "dirShadowMap", maxShadowResolution, 1?i32, 0?u32)
yar shadowMapSpot ShadowMap = NewShadowMap(depthProgram, "spotShadowMap", maxShadowResolution/3?i32, 1?i32, 1?u32)
yar shadowMapPoint ShadowMap = NewShadowCubeMap(depthProgramPoint, "pointShadowMap", maxShadowResolution/3?i32, 1?i32, 2?u32)

game->AddShadowMap(shadowMapDir) /*type: 0*/
game->AddShadowMap(shadowMapPoint) /*type: 1*/
game->AddShadowMap(shadowMapSpot) /*type: 2*/

yar b Light = NewPointLight(new Vec3{
    X: 0,
    Y: 4,
    Z: 0,
}, new Vec3{
    X: 2,
    Y: 2,
    Z: 2,
}, 20.0)
/*yar b Light = NewDirectionalLight(new Vec3{
    X: -0.3,
    Y: -1,
    Z: 0.5,
}, new Vec3{
    X: 2,
    Y: 2,
    Z: 2,
})*/


yar workspace Workspace = NewWorkspace("main", true, shaderProgram)

yar mesh Mesh = LoadMesh("shit/plate.glb")

yar meshCube Mesh = LoadMesh("shit/cube_metal.glb")

yar meshCube MeshObject = NewMeshObject("cube", meshCube)
meshCube->Position = new Vec3{
    X: -6, Y: 1, Z: 0,
}

yar meshObject MeshObject = NewMeshObject("sigma", mesh)
meshObject->Scale = new Vec3{
    X: 20, Y: 0.15, Z: 20,
}
meshObject->Position = new Vec3{
    X: 0, Y: -2, Z: 0,
}

yar meshObject2 MeshObject = NewMeshObject("sigma2", mesh)
meshObject2->Position = new Vec3{
    X: 6, Y: 1, Z: 0,
}

/*yar animation Animation = meshObject->Animations[2]

animation->Looped = false
animation->Play()*/

game->ListenInput(KEY_A, false)
game->ListenInput(KEY_D, false)
game->ListenInput(KEY_W, false)
game->ListenInput(KEY_S, false)
game->ListenInput(KEY_LEFT_SHIFT, false)
game->ListenInput(KEY_LEFT_CONTROL, false)

workspace->AddObject(meshObject)
workspace->AddObject(meshObject2)
workspace->AddObject(meshCube)

game->AddWorkspace(workspace)

game->AddLightSrc(b)

yar camera Camera = game->GetCamera()

yar delta f32 = 0.0

func Update(d f32) {
    delta = d
}

yar yaw f32, pitch f32 = 0, 0
yar sensitivity f32 = 0.1

yar moveSpeed f32 = 1

yar lastX f32, lastY f32 = 0, 0
func OnCursorEvent(x f32, y f32) {
    yar relX f32, relY f32 = x - lastX, lastY - y

    relX = relX * sensitivity
    relY = relY * sensitivity

    yaw = yaw + relX
    pitch = pitch + relY

    if pitch > 89?f32 {
        pitch = 89?f32
    }else if pitch < -89?f32 {
        pitch = -89?f32
    }

    yar front Vec3 = new Vec3{
        X: cos32(degToRad32(yaw)) * cos32(degToRad32(pitch)),
        Y: sin32(degToRad32(pitch)),
        Z: sin32(degToRad32(yaw)) * cos32(degToRad32(pitch)),
    }

    camera->Front = front->Norm()

    lastX, lastY = x, y
}

yar sprinting bool, sneaking bool = false, false

func OnInputEvent(key i32, action i32, mouse bool) {
    if key == KEY_LEFT_CONTROL {
        if action == PRESS {
            sneaking = true
            sprinting = false
        } else if action == RELEASE {
            sneaking = false
        }
    }
    
    if key == KEY_LEFT_SHIFT {
        if action == PRESS {
            sprinting = true
            sneaking = false
        } else if action == RELEASE {
            sprinting = false
        }
    }

    if sprinting == true {
        moveSpeed = 10?f32
    }else if sneaking == true {
        moveSpeed = 0.1?f32
    }else {
        moveSpeed = 1?f32
    }

    if action != PRESS {
        return void
    }

    if key == KEY_A {
        camera->Position = camera->Position->Add(camera->CameraRight->Mul(moveSpeed)->Mul(delta))
    }
    if key == KEY_D {
        camera->Position = camera->Position->Sub(camera->CameraRight->Mul(moveSpeed)->Mul(delta))
    }
    if key == KEY_W {
        camera->Position = camera->Position->Add(camera->Front->Mul(moveSpeed)->Mul(delta))
    }
    if key == KEY_S {
        camera->Position = camera->Position->Sub(camera->Front->Mul(moveSpeed)->Mul(delta))
    }
}